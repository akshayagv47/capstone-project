{
  "info": {
    "_postman_id": "9df79653-7eb6-4d96-9a57-c8e64e456e0c",
    "name": "Capstone Task4 API Validation",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Health is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "2. Register",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.collectionVariables.set('email', 'task4_' + Date.now() + '@example.com');",
              "pm.collectionVariables.set('password', 'Pass@12345');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Register is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"role\": \"CLIENT\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "register"
          ]
        }
      }
    },
    {
      "name": "3. Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Login is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.collectionVariables.set('jwtToken', body.token);"
            ]
          }
        }
      ]
    },
    {
      "name": "4. Create API Key",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwtToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/keys",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "keys"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Create API key is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const body = pm.response.json();",
              "pm.collectionVariables.set('apiKey', body.apiKey.key);",
              "pm.collectionVariables.set('apiSecret', body.apiSecret);"
            ]
          }
        }
      ]
    },
    {
      "name": "5. States",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "x-api-key",
            "value": "{{apiKey}}"
          },
          {
            "key": "x-api-secret",
            "value": "{{apiSecret}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/b2b/locations/states",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "b2b",
            "locations",
            "states"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('States is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.test('States has data', function () {",
              "  pm.expect(Array.isArray(body.data)).to.eql(true);",
              "  pm.expect(body.data.length).to.be.above(0);",
              "});",
              "pm.collectionVariables.set('stateId', body.data[0].id);"
            ]
          }
        }
      ]
    },
    {
      "name": "6. Districts By State",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "x-api-key",
            "value": "{{apiKey}}"
          },
          {
            "key": "x-api-secret",
            "value": "{{apiSecret}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/b2b/locations/states/{{stateId}}/districts",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "b2b",
            "locations",
            "states",
            "{{stateId}}",
            "districts"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Districts is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.test('Districts response shape', function () {",
              "  pm.expect(Array.isArray(body.data)).to.eql(true);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "7. Search q=ram",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "x-api-key",
            "value": "{{apiKey}}"
          },
          {
            "key": "x-api-secret",
            "value": "{{apiSecret}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/b2b/locations/search?q=ram",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "b2b",
            "locations",
            "search"
          ],
          "query": [
            {
              "key": "q",
              "value": "ram"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Search is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.test('Search response shape', function () {",
              "  pm.expect(Array.isArray(body.data)).to.eql(true);",
              "});"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
